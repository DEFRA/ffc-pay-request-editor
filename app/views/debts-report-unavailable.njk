{% extends '_layout.njk' %}

{% set mainClasses = "govuk-main-wrapper--l" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [{
      text: "Home",
      href: "/"
    }, {
      text: "Capture reporting data",
      href: "/capture"
    }, {
      text: "Debts report unavailable"
    }]
  })}}
{% endblock %}

{% block content %}
  <main class="govuk-main-wrapper " id="main-content" role="main">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-l">Debts report unavailable</h1>
        <p class="govuk-body">
          There are currently no debts.
        </p>
      </div>
    </div>
  </main>
{% endblock %}

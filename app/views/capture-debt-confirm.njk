{% extends '_layout.njk' %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% set pageTitle = "Check new reporting dataset is correct before creating" %}

{% block pageTitle %}{{ pageTitle }} - {{ serviceName }}{% endblock %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [{
      text: "Home",
      href: "/"
    }, {
      text: "Manage unattached debt data",
      href: "/capture"
    }, {
      text: "Create new debt data",
      href: "/capture-debt"
    }, {
      text: pageTitle
    }]
  })}}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ pageTitle }}</h1>
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">
            New reporting dataset
          </h2>
          <ul class="govuk-summary-card__actions">
            <li class="govuk-summary-card__action">
              <a class="govuk-link" href="/capture-debt?scheme={{ scheme }}&frn={{ frn }}&applicationIdentifier={{ applicationIdentifier }}&net={{ net }}&debtType={{ debtType }}&debt-discovered-day={{ debtDiscoveredDay }}&debt-discovered-month={{ debtDiscoveredMonth }}&debt-discovered-year={{ debtDiscoveredYear }}">Change<span class="govuk-visually-hidden"> reporting dataset</span></a>            </li>
          </ul>
        </div>
        <div class="govuk-summary-card__content">
          <dl class="govuk-summary-list">
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">
                Scheme
              </dt>
              <dd class="govuk-summary-list__value">
                {{ scheme }}
              </dd>
            </div>
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">
                FRN (Firm Reference Number)
              </dt>
              <dd class="govuk-summary-list__value">
                {{ frn }}
              </dd>
            </div>
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">
                Agreement / claim number
              </dt>
              <dd class="govuk-summary-list__value">
                {{ applicationIdentifier }}
              </dd>
            </div>
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">
                Net value
              </dt>
              <dd class="govuk-summary-list__value">
                {{ net }}
              </dd>
            </div>
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">
                Debt type
              </dt>
              <dd class="govuk-summary-list__value">
                {{ debtType }}
              </dd>
            </div>
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">
                Date debt discovered
              </dt>
              <dd class="govuk-summary-list__value">
                {{ debtDiscoveredDay }}/{{ debtDiscoveredMonth }}/{{ debtDiscoveredYear }}
              </dd>
            </div>
          </dl>
        </div>
      </div>

      <form method="POST" action="/capture-debt" autocomplete="off" novalidate>
        <input type="hidden" name="crumb" value="{{ crumb }}"/>
        <input type="hidden" name="scheme" value="{{ scheme }}"/>
        <input type="hidden" name="frn" value="{{ frn }}"/>
        <input type="hidden" name="applicationIdentifier" value="{{ applicationIdentifier }}"/>
        <input type="hidden" name="net" value="{{ net }}"/>
        <input type="hidden" name="debtType" value="{{ debtType }}"/>
        <input type="hidden" name="debt-discovered-day" value="{{ debtDiscoveredDay }}"/>
        <input type="hidden" name="debt-discovered-month" value="{{ debtDiscoveredMonth }}"/>
        <input type="hidden" name="debt-discovered-year" value="{{ debtDiscoveredYear }}"/>
        <button class="govuk-button" id="submit">
          Save
        </button>
      </form>
    </div>
  </div>
{% endblock %}

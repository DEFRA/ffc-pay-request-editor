{% extends '_layout.njk' %}

{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "macros/search-input.njk" import searchInput %}

{% set pageTitle = "Manual ledger assignment" %}

{% block pageTitle %}{{ pageTitle }} - {{ serviceName }}{% endblock %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [{
      text: "Home",
      href: "/"
    }, {
      text: pageTitle
    }]
  })}}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {% if checkComplete %}
        <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="govuk-notification-banner-title" data-module="govuk-notification-banner">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="govuk-notification-banner-title-hold-added">
              Success
            </h2>
          </div>
          <div class="govuk-notification-banner__content">
            <h3 class="govuk-notification-banner__heading">
              Ledger assignment for {{ checkComplete }} has been updated and sent for quality checking.
            </h3>
          </div>
        </div>
      {% endif %}
      <h1 class="govuk-heading-l">{{ pageTitle }}</h1>
      <p class="govuk-body">
        Payment requests that have been modified will need to be compared to the original amount, and if needed, adjusted to make sure the customer is paid correctly.
      </p>
      <p class="govuk-body">
        Review assignments awaiting quality check or search for an individual assignment using the FRN (Firm Reference Number).
      </p>
      {% if ledgerData.length %}
        <div class="govuk-!-padding-bottom-3">
          <div class="govuk-!-width-one-third">
            <form action="/manual-ledger" method="POST">
              <input type="hidden" name="crumb" value="{{crumb}}"/>
              {{ searchInput(model) }}
              <div class="govuk-button-group">
                {{ govukButton({
                    text: "Search",
                    classes: "govuk-button govuk-!-margin-top-2"
                  }) 
                }}
                <a href="/manual-ledger" class="govuk-link govuk-link--no-visited-state">Reset table</a>
              </div>
            </form>
          </div>

          <div class="govuk-grid-row">
            <div class="govuk-grid-column-one-half">
              <div style="display:flex;align-items:baseline;gap:1rem;">
                <h2 class="govuk-heading-m govuk-!-margin-0">Ledger assignments</h2>
              </div>
            </div>

            <div class="govuk-grid-column-one-half govuk-!-padding-top-1">
              <div style="display:flex;align-items:baseline;justify-content:flex-end;">
                <div class="govuk-body-s" aria-label="Records per page" style="white-space:nowrap;vertical-align:baseline;">
                  <span>Number of records per page:</span>&nbsp;
                  {% set perPageOptions = [100, 500, 1000] %}
                  <form id="perPageForm" action="/enrich" method="get" style="display:inline;vertical-align:baseline;">
                    <input type="hidden" name="perPage" id="perPageInput" value="{{ perPage }}">
                    <input type="hidden" name="page" value="1">
                    {% for opt in perPageOptions %}
                      {% if perPage == opt %}
                        <strong>{{ opt }}</strong>
                      {% else %}
                        <a href="#" class="govuk-link perpage-link" data-perpage="{{ opt }}">{{ opt }}</a>
                      {% endif %}
                      {% if not loop.last %} &nbsp;|&nbsp; {% endif %}
                    {% endfor %}
                  </form>
                </div>
              </div>
            </div>
          </div>

          {% set tableRows = [] %}
          {% for data in ledgerData %}
            {% set actionHtml %}
              {% if not data.manualLedgerChecked %}
                <a href="/manual-ledger-check?paymentrequestid={{data.paymentRequestId}}" class="govuk-link" aria-label="Review invoice {{ data.invoiceNumber }} for FRN {{ data.frn }}">Review</a>
              {% endif %}
            {% endset %}

            {% set tableRows = (tableRows.push([
              { text: data.schemeName, classes: "govuk-body-s" },
              { text: data.marketingYear, classes: "govuk-body-s" },
              { text: data.frn, classes: "govuk-body-s" },
              { text: data.agreementNumber, classes: "govuk-body-s" },
              { text: data.invoiceNumber, classes: "govuk-body-s" },
              { text: data.paymentRequestNumber, format: "numeric", classes: "govuk-body-s" },
              { text: data.valueText, format: "numeric", classes: "govuk-body-s noWrap" },
              { text: data.receivedFormatted, classes: "govuk-body-s" },
              { html: actionHtml, classes: "govuk-body-s" }
            ]), tableRows) %}
          {% endfor %}

          {{ govukTable({
            head: [
              { text: "Scheme", classes: "govuk-body-s" },
              { text: "Scheme Year", classes: "govuk-body-s" },
              { text: "FRN", classes: "govuk-body-s" },
              { text: "Agreement number", classes: "govuk-body-s" },
              { text: "Invoice number", classes: "govuk-body-s" },
              { text: "Requests", format: "numeric", classes: "govuk-body-s" },
              { text: "Total amount", format: "numeric", classes: "govuk-body-s" },
              { text: "Received", classes: "govuk-body-s" },
              { text: "Actions", classes: "govuk-body-s" }
            ],
            rows: tableRows
          }) }}

          {% set paginationItems = [] %}
          {% if page > 1 %}
            {% set paginationPrevious = {
              href: "?page=" + (page - 1) + "&perPage=" + perPage,
              labelText: "Previous page"
            } %}
          {% endif %}

          {% if ledgerData.length >= perPage %}
            {% set paginationNext = {
              href: "?page=" + (page + 1) + "&perPage=" + perPage,
              labelText: "Next page"
            } %}
          {% endif %}

          {{ govukPagination({
            previous: paginationPrevious,
            next: paginationNext,
            items: [
              {
                number: page,
                current: true
              }
            ]
          }) }}
        </div>
      {% else %}
        <div class="govuk-inset-text">
          {% if frn %}
            No ledger assignments were found for the FRN. Check details and try again, or 
            <a href="/manual-ledger" class="govuk-link govuk-link--no-visited-state">reset table</a> 
            to view all datasets awaiting ledger assignments.
          {% else %}
            No ledger assignments were found.
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
  <script>
    document.querySelectorAll('.perpage-link').forEach(link => {
      link.addEventListener('click', function (e) {
        e.preventDefault()
        const newVal = this.dataset.perpage
        const input = document.getElementById('perPageInput')
        if (!input || String(input.value) === String(newVal)) return
        input.value = newVal
        document.getElementById('perPageForm').submit()
      })
    })
  </script>
{% endblock %}